# Ключ django
SECRET_KEY=<Ключ от Django>

# Режим дебага (разработки)
DEBUG=True

# Настройки для подключения к БД
NAME=learning_website
USER=<Пользователь БД>
PASSWORD=<Пароль от БД>
HOST=<Хост БД>
PORT=<Порт БД>

# Ключ для платежного сервиса Stripe
STRIPE_API_KEY=<ключ от Stripe>

# Настройки почтового клиента
EMAIL_HOST = smtp.yandex.ru
EMAIL_PORT = 465
EMAIL_USE_TLS = False
EMAIL_USE_SSL = True
EMAIL_HOST_USER =
EMAIL_HOST_PASSWORD =

# Настройки Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0